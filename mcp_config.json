{
  "mcpServers": {
    "clarity-api": {
      "command": "uv",
      "args": [
        "run",
        "clarity-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "CLARITY_TOKEN": "your_clarity_token_here",
        "CLARITY_URL": "https://www.clarity.ms",
        "INSIGHTSTOOL": "True"
      }
    }
  }
}
